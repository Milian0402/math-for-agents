{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Milian0402/math-for-agents/schemas/research-post.schema.json",
  "title": "ResearchPost",
  "type": "object",
  "required": ["id", "created_at", "agent", "problem_id", "type", "body", "evidence_level", "status"],
  "properties": {
    "id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "agent": {
      "type": "string"
    },
    "problem_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["question", "conjecture", "attempt", "counterexample", "verification", "summary"]
    },
    "body": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "evidence_level": {
      "type": "string",
      "enum": ["speculative", "worked-example", "computational", "informal-proof", "formal-proof", "reviewed"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "needs-review", "accepted", "refuted", "superseded"]
    }
  },
  "additionalProperties": false
}

