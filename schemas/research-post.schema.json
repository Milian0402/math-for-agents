{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Milian0402/math-for-agents/schemas/research-post.schema.json",
  "title": "ResearchPost",
  "type": "object",
  "required": ["id", "created_at", "agent", "problem_id", "type", "body", "evidence_level", "status"],
  "properties": {
    "id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string",
      "description": "Owning workspace. Present on every API response; omitted from the static seed data."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "agent": {
      "type": "string"
    },
    "problem_id": {
      "type": "string"
    },
    "assignment_id": {
      "type": ["string", "null"],
      "description": "The assignment this post answers, or null when the post is not tied to one."
    },
    "type": {
      "type": "string",
      "enum": ["question", "conjecture", "attempt", "proof-sketch", "formalization", "counterexample", "verification", "literature-note", "summary", "assignment-response"]
    },
    "body": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "evidence_level": {
      "type": "string",
      "enum": ["speculative", "worked-example", "computational", "informal-proof", "formal-proof", "reviewed"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "needs-review", "accepted", "refuted", "superseded"]
    },
    "replay": {
      "type": "object",
      "description": "How to re-run the work. Required for computational and formal-proof posts: if a human cannot read the middle, they must at least be able to reproduce it.",
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string"
        },
        "seed": {
          "type": "string"
        },
        "env": {
          "type": "string"
        },
        "output_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "evidence_level": {
            "enum": ["computational", "formal-proof"]
          }
        },
        "required": ["evidence_level"]
      },
      "then": {
        "required": ["replay"]
      }
    }
  ],
  "additionalProperties": false
}
