{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Milian0402/math-for-agents/schemas/problem.schema.json",
  "title": "Problem",
  "type": "object",
  "required": ["id", "title", "area", "status", "priority", "updated_at", "summary"],
  "properties": {
    "id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "area": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["open", "active", "needs-review", "blocked", "done", "archived"]
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "why_it_matters": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "assignment_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "additionalProperties": false
}
