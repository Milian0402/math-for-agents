PORT=4173
HOST=127.0.0.1
DATABASE_URL=postgres://math_for_agents:math_for_agents@127.0.0.1:55432/math_for_agents
DATABASE_SSL=false
ARTIFACT_STORAGE_DIR=artifacts
ARTIFACT_MAX_BYTES=10000000
# Optional request JSON cap. Defaults to artifact max with base64 overhead.
MAX_JSON_BYTES=
MFA_WORKSPACE_ID=workspace:default
MFA_WORKSPACE_NAME=math-for-agents
MFA_HUMAN_ID=human:max
MFA_HUMAN_EMAIL=max@example.com
MFA_HUMAN_NAME=Max
MFA_HUMAN_PASSWORD=mfa_dev_password
MFA_HUMAN_KEY=mfa_dev_human_key
MFA_SESSION_DAYS=14
MFA_COOKIE_SECURE=false
# Only use this for a trusted HTTP-only local/private deploy.
MFA_ALLOW_INSECURE_COOKIES=false
# Optional comma-separated browser origins allowed for cookie-auth writes.
MFA_PUBLIC_ORIGIN=
MFA_WORKER_RUNNER=disabled
MFA_WORKER_POLL_MS=5000
MFA_WORKER_TIMEOUT_MS=60000
MFA_WORKER_MAX_OUTPUT_BYTES=256000
MFA_WORKER_IMAGE=python:3.12-alpine
MFA_WORKER_DOCKER_CPUS=1
MFA_WORKER_DOCKER_MEMORY=512m
MFA_RATE_LIMIT_ENABLED=true
MFA_RATE_LIMIT_WINDOW_MS=60000
MFA_RATE_LIMIT_LOGIN_MAX=10
MFA_RATE_LIMIT_WRITE_MAX=120
MFA_RATE_LIMIT_READ_MAX=600
MFA_TRUST_PROXY=false
MFA_LOG_REQUESTS=true
BACKUP_DIR=backups
# Optional mounted/off-host target. The backup script copies each verified backup directory here.
BACKUP_REMOTE_DIR=
MFA_BASE_URL=http://127.0.0.1:4173
MFA_HEALTHCHECK_TIMEOUT_MS=5000
# Optional. Set to a human or agent key if you want the healthcheck to verify auth too.
MFA_HEALTHCHECK_BEARER=
MFA_HEALTHCHECK_ASSIGNMENTS=false

# Production containers should use:
# HOST=0.0.0.0
# MFA_HUMAN_KEY=<long random secret>
# MFA_HUMAN_PASSWORD=<long random password>
# MFA_COOKIE_SECURE=true
# MFA_ALLOW_INSECURE_COOKIES=false
# MFA_PUBLIC_ORIGIN=https://math-for-agents.example.com
# MFA_TRUST_PROXY=true when running behind a trusted reverse proxy that sets x-forwarded-for
# MFA_WORKER_RUNNER=docker
# DATABASE_SSL=true when hosted Postgres requires TLS
